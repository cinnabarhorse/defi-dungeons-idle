# Test environment configuration
# Copy to .env.test and fill in values

# Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase service role key (server-side)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase anonymous key (client-side)
SUPABASE_ANON_KEY=your-anon-key

# Database connection string for tests (pooler or direct)
# Provide SUPABASE_DB_URL or DATABASE_URL
SUPABASE_DB_URL=
DATABASE_URL=

# Optional variables
SIM_SEED=12345
DEBUG_LOGS=0
GOTCHI_SPRITES_BACKEND=mock
# Environment variables for testing
# Copy this file to .env.test and fill in values for your test environment
#
# Required for test:agent and test:fast to work properly

# === Database Configuration ===
# Test database URL (use a separate database for tests to avoid data conflicts)
SUPABASE_DB_URL=""
SUPABASE_DB_URL_NON_POOLING=""
DATABASE_POOL_MAX=5

# === Supabase Configuration ===
# You can use the same Supabase instance with a test database, or a local Supabase
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# === Thirdweb Configuration (optional for tests) ===
# Only needed if tests interact with wallet/auth features
THIRDWEB_CLIENT_ID="test-client-id"
THIRDWEB_SECRET_KEY="test-secret-key"

# === Test-specific Settings ===
# Disable SIWE auth for faster tests
NEXT_PUBLIC_DISABLE_SIWE=1

# Disable external network calls in tests
NODE_ENV=test

# === Simulation Settings ===
# Fixed seed for deterministic simulation tests
SIM_SEED=12345

# Disable sprite generation during tests
GOTCHI_SPRITES_BACKEND=mock

# === Debug Settings ===
# Enable debug logs in test output (set to 0 to reduce noise)
DEBUG_LOGS=0
