# Test environment configuration.
# Copy to .env.test and fill in values for local test runs.

# Database and Supabase.
# Use a test database, not production.
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_DB_URL=""
SUPABASE_DB_URL_NON_POOLING=""
DATABASE_URL=""
DATABASE_POOL_MAX=5

# Client/auth values used by focused tests.
NEXT_PUBLIC_THIRDWEB_CLIENT_ID="test-client-id"
THIRDWEB_CLIENT_ID="test-client-id"
THIRDWEB_SECRET_KEY="test-secret-key"
NEXT_PUBLIC_DISABLE_SIWE=1

# Deterministic test behavior.
NODE_ENV=test
SIM_SEED=12345
GOTCHI_SPRITES_BACKEND=mock
DEBUG_LOGS=0
