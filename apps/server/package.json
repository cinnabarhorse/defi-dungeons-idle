{
  "name": "@gotchiverse/server",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "pre-dev": "echo '🔧 Server is self-contained, no dependencies to build'",
    "predev": "pnpm -w stop && pnpm run pre-dev",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@colyseus/schema": "^2.0.0",
    "@supabase/supabase-js": "^2.48.0",
    "colyseus": "^0.15.0",
    "compression": "^1.8.1",
    "cookie": "^0.6.0",
    "cors": "^2.8.0",
    "dotenv": "^17.2.2",
    "ethers": "^6.13.0",
    "express": "^4.18.0",
    "gotchi-generator": "1.1.3",
    "graphql": "^16.11.0",
    "graphql-request": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.2.1",
    "pg": "^8.12.0",
    "pino": "^7.11.0",
    "pino-std-serializers": "^4.0.0",
    "siwe": "^2.1.6",
    "viem": "^2.37.3"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.10.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0"
  }
}
