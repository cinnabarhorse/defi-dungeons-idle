{
  "name": "@gotchiverse/client",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@8.12.0",
  "scripts": {
    "prebuild": "tsx scripts/prebuild-optimize.ts",
    "build": "npm run prebuild && NODE_OPTIONS='--max-old-space-size=4096' next build",
    "pre-dev": "echo '🔧 Building client dependencies...' && cd ../../packages/types && pnpm build && cd ../shared && pnpm build && cd ../../apps/client",
    "predev": "pnpm -w stop && pnpm run pre-dev",
    "dev": "next dev -p 3001 -H 0.0.0.0",
    "start": "next start -p 3001",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "PWDEBUG=1 playwright test --ui"
  },
  "dependencies": {
    "@base-org/account": "^2.4.2",
    "@farcaster/miniapp-sdk": "^0.2.1",
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-dialog": "^1.0.0",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slider": "^1.1.0",
    "@radix-ui/react-switch": "^1.0.0",
    "@radix-ui/react-tabs": "^1.0.0",
    "@radix-ui/react-tooltip": "^1.0.0",
    "@supabase/supabase-js": "^2.57.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "cmdk": "^1.1.1",
    "colyseus.js": "^0.15.0",
    "framer-motion": "^12.23.24",
    "idb-keyval": "^6.2.1",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.294.0",
    "next": "^14.0.0",
    "next-pwa": "^5.6.0",
    "nuqs": "^1.20.0",
    "phaser": "^3.87.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "siwe": "^2.1.6",
    "swr": "^2.2.0",
    "tailwind-merge": "^2.0.0",
    "tailwindcss": "^3.3.0",
    "thirdweb": "^5.27.1",
    "viem": "^2.37.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.54.0",
    "eslint-config-next": "^14.0.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0",
    "postcss": "^8.4.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
